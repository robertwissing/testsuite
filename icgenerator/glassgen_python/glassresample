#!/bin/bash
# glassresample: split or merge a tipsy snapshot (gas + all aux fields) with
# the Python icgenerator.
#
# usage: glassresample <tipsy.NNNNN> [resample_cli options...]
#
#   glassresample pre.00000 --op split --factor 8
#   glassresample fine.00000 --op merge --factor 8 -o coarse
#
# Defaults derived from the input name (overridden by passing the flag
# yourself):
#   --param <input minus .NNNNN>.param   (when that file exists)
#   -o      <input minus .NNNNN>_<op>     (writes ..._<op>.00000 + aux)
# Everything else (--op, --factor, -s, --dist, --margin, ...) is passed
# straight to glassgen.resample_cli; run with --help to list.
set -euo pipefail

pkgroot=$(cd "$(dirname "$0")" && pwd)

if [[ $# -lt 1 || $1 == -h || $1 == --help ]]; then
    echo "usage: $(basename "$0") <tipsy file> [options]"
    echo
    PYTHONPATH=$pkgroot python -m glassgen.resample_cli --help
    exit 0
fi

infile=$1; shift
[[ -f $infile ]] || { echo "glassresample: no such file: $infile" >&2; exit 1; }

base=$infile
[[ $infile =~ ^(.*)\.[0-9]+$ ]] && base=${BASH_REMATCH[1]}

args=("$@")
have_out=0 have_box=0 op=split
prev=
for a in "${args[@]}"; do
    case $a in
        -o) have_out=1 ;;
        --param|--param=*|--box|--open) have_box=1 ;;
    esac
    [[ $prev == --op ]] && op=$a
    [[ $a == --op=* ]] && op=${a#--op=}
    prev=$a
done
((have_out)) || args+=(-o "${base}_${op}")
if ((!have_box)); then
    if [[ -f $base.param ]]; then
        args+=(--param "$base.param")
    else
        echo "glassresample: no $base.param found - pass --param, --box LX LY LZ, or --open" >&2
        exit 1
    fi
fi

exec env PYTHONPATH=$pkgroot${PYTHONPATH:+:$PYTHONPATH} \
    python -m glassgen.resample_cli -I "$infile" "${args[@]}"
